# 도란도란 frontend 환경변수 예시
# 실제 .env / .env.local 은 커밋하지 마세요.

# 백엔드 API base URL (prefix /api/v1 은 client 에서 자동 부여)
VITE_API_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------
# 로그인 화면 시연 카드 노출 여부
# ---------------------------------------------------------------
# true 로 두면 로그인 화면에 백엔드 seed 계정(@test.com) 자동입력 카드가 표시됩니다.
# 카드의 "입력하기" 버튼은 email/password 만 채워주며, 로그인 자체는 실제 백엔드
# /api/v1/auth/login 호출로 이루어집니다. (demo token 사용 안 함)
#
# 표시되는 seed 계정 (백엔드 DataInitializer 가 생성):
#   youth_approved@test.com  -> /youth (승인 완료)
#   guardian@test.com        -> /guardian/dashboard
#   admin@test.com           -> /admin
#   youth@test.com           -> /youth
#   youth_pending@test.com   -> 승인 대기 팝업
#   youth_rejected@test.com  -> 반려 안내 팝업
#   youth_banned@test.com    -> 제재 안내 팝업
#
# 운영/스테이징에는 seed 계정이 없으므로 반드시 false 로 두세요. 기본값은 false.
VITE_SHOW_DEMO_ACCOUNTS=false

# ---------------------------------------------------------------
# 프론트 단독 데모 로그인 모드 (@demo.com 전용)
# ---------------------------------------------------------------
# true 로 두면 백엔드 없이도 @demo.com 계정으로 화면 흐름을 확인할 수 있습니다.
# 이 플래그는 @demo.com 계정에만 적용되며, @test.com seed 계정에는 영향을 주지 않습니다.
# 운영/스테이징에는 절대 true 로 두지 마세요. 기본값은 false.
#
# 로컬에서 프론트 단독 데모로 시연하려면 .env.development.local 에 추가하세요:
#   VITE_ENABLE_DEMO_LOGIN=true
#   VITE_SHOW_DEMO_ACCOUNTS=true
#
# @demo.com 계정 (프론트 단독, 비밀번호 임의):
#   youth@demo.com     -> /youth
#   guardian@demo.com  -> /guardian/dashboard
#   admin@demo.com     -> /admin
#   senior@demo.com    -> /senior (Device 인증은 화면에서 별도 진행)
#   pending@demo.com   -> 승인 대기 팝업
#   rejected@demo.com  -> 반려 안내 팝업
#   suspended@demo.com -> 제재 안내 팝업
VITE_ENABLE_DEMO_LOGIN=false
