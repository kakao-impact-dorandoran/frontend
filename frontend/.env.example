# 도란도란 frontend 환경변수 예시
# 실제 .env / .env.local 은 커밋하지 마세요.

# 백엔드 API base URL (prefix /api/v1 은 client 에서 자동 부여)
VITE_API_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------
# 시연용 계정 자동 입력 UI
# ---------------------------------------------------------------
# true 로 설정한 환경에서만 로그인 화면 하단에 시연 계정 카드가 보입니다.
# 실제 ID/비밀번호는 이 파일에 적지 말고 .env.development.local 에만 넣으세요.
# (.env*.local 은 .gitignore 로 추적되지 않습니다.)

VITE_SHOW_DEMO_ACCOUNTS=false

VITE_DEMO_YOUTH_ID=youth_approved
VITE_DEMO_YOUTH_PASSWORD=

VITE_DEMO_GUARDIAN_ID=guardian
VITE_DEMO_GUARDIAN_PASSWORD=

VITE_DEMO_ADMIN_ID=admin
VITE_DEMO_ADMIN_PASSWORD=
